{
  "name": "commit-manager",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "scripts": {
    "cli": "tsx bin/cli.ts",
    "build:cli": "node scripts/build-cli.mjs",
    "compile": "npm run build:cli && pkg dist/cli.cjs --targets node20-macos-arm64,node20-macos-x64,node20-linux-x64,node20-win-x64 --output dist/bin/commit-planner",
    "install:cli": "./install.sh",
    "uninstall:cli": "./uninstall.sh",
    "release": "node scripts/release.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "diff": "^5.2.2",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@yao-pkg/pkg": "^6.14.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
